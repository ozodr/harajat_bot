# 🔑 .env fayli - bu faylni .env nomi bilan saqlang

# Telegram Bot Token - @BotFather dan oling
BOT_TOKEN=your_telegram_bot_token_here

# Gemini API Key - aistudio.google.com dan oling
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI API Key (ixtiyoriy - faqat ovozli xabar uchun kerak)
# platform.openai.com dan oling
OPENAI_API_KEY=your_openai_api_key_here
